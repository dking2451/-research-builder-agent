# PostgreSQL connection (SQLAlchemy URL)
# Homebrew postgresql@* on Mac: default DB user is usually your macOS login (`whoami`), not "postgres".
# Example (replace YOUR_USER): postgresql+psycopg://YOUR_USER@localhost:5432/research_builder
# Docker / Linux images often use user "postgres" with a password — match your actual server.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/research_builder

# OpenAI
OPENAI_API_KEY=

# Optional: model override (defaults in app/config.py)
OPENAI_MODEL=gpt-4o-mini

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Default user email for single-user bootstrap (seed creates this user)
DEFAULT_USER_EMAIL=you@example.com

# Demo mode without OpenAI calls
USE_STUB_AGENT=false
